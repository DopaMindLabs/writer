        data-tour="tour-citations-add"
      >
        <div
          class="w-full md:w-[360px] md:max-w-[40%]"
        >
          <div
            class="group flex w-full items-center gap-2 border-b border-rule transition-colors focus-within:border-ink text-[12px]"
          >
            <svg
              aria-hidden="true"
              class="lucide lucide-search h-3.5 w-3.5 shrink-0 text-ink-3"
              fill="none"
              height="24"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
