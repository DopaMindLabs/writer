          />
        </svg>
      </button>
    </div>
  </div>
  <div
    class="flex min-h-0 flex-1 flex-col"
  >
    <div
      class="flex h-full flex-1 flex-col overflow-hidden bg-paper"
      data-testid="citations-pane"
    >
      <div
        class="border-b border-rule py-4 px-4"
      >
        <div
          class="flex items-baseline justify-between"
        >
          <div
            class="font-mono text-[10px] uppercase tracking-[0.08em]"
