// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`SyncResultsTable > snapshot > should match the snapshot of the per-space results table 1`] = `
<div>
  <div
    class="mt-6"
  >
    <h3
      class="font-mono uppercase text-ink-3 text-[10px] tracking-[0.08em]"
    >
      Last run
    </h3>
    <table
      class="mt-3 w-full border-collapse text-[13px]"
      data-testid="sync-results"
    >
      <tbody>
        <tr
          class="border-b border-rule"
          data-testid="sync-result-s1"
        >
          <td
            class="py-2.5 text-[13px] text-ink"
          >
            Novel
          </td>
          <td
            class="py-2.5 text-right"
          >
            <span
              class="inline-flex items-center gap-1.5 border font-mono uppercase tracking-[0.08em] border-success/30 bg-success-bg text-success px-1.5 py-1 text-[10px]"
            >
              <svg
                aria-hidden="true"
                class="lucide lucide-check h-3 w-3"
                fill="none"
                height="24"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                viewBox="0 0 24 24"
                width="24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M20 6 9 17l-5-5"
                />
              </svg>
              <span>
                synced
              </span>
            </span>
          </td>
        </tr>
        <tr
          class="border-b border-rule"
          data-testid="sync-result-s2"
        >
          <td
            class="py-2.5 text-[13px] text-ink"
          >
            Essays
          </td>
          <td
            class="py-2.5 text-right"
          >
            <span
              class="inline-flex items-center gap-1.5 border font-mono uppercase tracking-[0.08em] border-danger/30 bg-danger-bg text-danger px-1.5 py-1 text-[10px]"
            >
              <svg
                aria-hidden="true"
                class="lucide lucide-x h-3 w-3"
                fill="none"
                height="24"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                viewBox="0 0 24 24"
                width="24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M18 6 6 18"
                />
                <path
                  d="m6 6 12 12"
                />
              </svg>
              <span>
                failed
              </span>
            </span>
            <span
              class="ml-2 font-mono text-[10px] text-ink-3"
            >
              disk full
            </span>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</div>
`;
