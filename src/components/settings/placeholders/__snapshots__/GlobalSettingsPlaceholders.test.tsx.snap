            <span
              class="inline-flex items-center justify-center border px-3.5 py-1.5 text-[12px] tracking-[0.01em] border-rule bg-paper text-ink"
            >
              30 days
            </span>
          </div>
        </div>
      </div>
      <div
        class="flex flex-col gap-2 border-b border-rule/60 py-4 md:grid md:grid-cols-[1fr_auto] md:items-center md:gap-8"
      >
        <div>
          <div
            class="text-[14px] font-medium text-ink"
          >
            Latest
          </div>
        </div>
        <div>
          <span
            class="font-serif text-[14px] text-ink"
          >
            12 min ago · 1,190 words
          </span>
        </div>
      </div>
    </section>
  </div>
</div>
`;
