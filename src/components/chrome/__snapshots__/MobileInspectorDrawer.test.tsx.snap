// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`snapshot > matches the open inspector drawer 1`] = `
<div
  aria-labelledby="radix-_r_*_"
  class="fixed inset-y-0 right-0 z-50 flex w-[min(320px,85vw)] bg-paper-2 shadow-lg md:hidden data-[state=open]:animate-in data-[state=closed]:animate-out data-[state=open]:slide-in-from-right data-[state=closed]:slide-out-to-right duration-200"
  data-state="open"
  data-testid="mobile-inspector-drawer"
  id="radix-_r_*_"
  role="dialog"
  style="pointer-events: auto;"
  tabindex="-1"
>
  <h2
    class="sr-only"
    id="radix-_r_*_"
  >
    Doc inspector
  </h2>
  <aside
    class="relative shrink-0 flex-col border-rule bg-paper-2 md:flex flex w-full border-l-0"
    data-testid="doc-inspector"
  >
    <div
      class="flex items-center gap-2 border-b border-rule px-4 py-3"
    >
