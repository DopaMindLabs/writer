        data-testid="doc-inspector-tab-outline"
        type="button"
      >
        OUTLINE
      </button>
      <button
        class="flex-1 border-b-2 px-1.5 py-2 text-center font-mono text-[9px] uppercase tracking-wider transition-colors border-transparent text-ink-3 hover:text-ink-2"
        data-testid="doc-inspector-tab-info"
        type="button"
      >
        INFO
      </button>
      <button
        class="flex-1 border-b-2 px-1.5 py-2 text-center font-mono text-[9px] uppercase tracking-wider transition-colors border-transparent text-ink-3 hover:text-ink-2"
        data-testid="doc-inspector-tab-history"
        type="button"
      >
        HISTORY
      </button>
      <button
        class="flex-1 border-b-2 px-1.5 py-2 text-center font-mono text-[9px] uppercase tracking-wider transition-colors border-transparent text-ink-3 hover:text-ink-2"
