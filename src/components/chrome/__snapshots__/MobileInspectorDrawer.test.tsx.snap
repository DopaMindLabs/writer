          >
            <span
              class="w-5 font-mono text-[8px] uppercase tracking-wider text-ink-4"
            >
              H1
            </span>
            <span
              class="flex-1 font-serif text-[13px] font-medium text-ink"
            >
              The bell-keeper's last morning
            </span>
          </div>
          <div
            class="flex items-baseline gap-2 border-l-2 py-1.5 pl-7 border-transparent"
          >
            <span
              class="w-5 font-mono text-[8px] uppercase tracking-wider text-ink-4"
            >
              H2
            </span>
            <span
              class="flex-1 font-serif text-[13px] text-ink-2"
            >
